AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4.1
AZURE_OPENAI_API_KEY=
APPLICATION_INSIGHTS_CONNECTION_STRING=InstrumentationKey=<key>;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/
OTEL_SERVICE_NAME=zava-travel-agent
OTEL_RECORD_CONTENT=false
OTEL_TRACES_SAMPLER=parentbased_trace_id_ratio
OTEL_TRACES_SAMPLER_ARG=0.1
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local
DEMO_FORCE_GOTO=false
DEMO_TOOL_FAILURE_RATE=0.0
DEMO_RETRIEVER_TOPK=3
BUILD_SHA=local
IMAGE_TAG=local
BUILD_ID=local
